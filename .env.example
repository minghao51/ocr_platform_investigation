# =============================================================================
# OCR Platform Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# VLM Provider API Keys
# -----------------------------------------------------------------------------
# At least ONE provider key is required for OCR functionality.
# Get free API keys from the following providers:

# Nebius AI (recommended for cost-effective vision models)
# Sign up: https://nebius.ai/
NEBIUS_API_KEY=your_nebius_api_key_here

# OpenRouter (aggregates many models, free tier available)
# Sign up: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini (via Google AI Studio)
# Sign up: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/ocr_platform.db

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no spaces).
# Either CORS_ORIGINS or CORS_ORIGINS_STR is accepted.
# For local development: http://localhost:5173,http://localhost:3000
# For production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate a secure key by running:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32-characters

# JWT algorithm (HS256 is recommended)
JWT_ALGORITHM=HS256

# Token expiration in hours
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# API requests per minute for OCR actions (admin/master accounts bypass this)
RATE_LIMIT_PER_MINUTE=10

# Daily OCR requests for limited demo accounts
DEMO_DAILY_REQUEST_LIMIT=5
